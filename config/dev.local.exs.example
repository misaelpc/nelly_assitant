# Copy to dev.local.exs (gitignored) and tune for your machine.
# Raspberry Pi + USB mic that works with:
#   arecord -D hw:2,0 -f S16_LE -c 2 -r 44100 -d 5 /tmp/test.wav
#
# Pick device_id from: mix eval "Membrane.PortAudio.print_devices()"
# (the line whose name matches your USB interface, e.g. hw:2,0).

import Config

config :nelly_assitant, :voice_pipeline,
  device_id: 0,
  channels: 2,
  sample_format: :s16le,
  sample_rate: 44_100

# Quiet mic for live Whisper: add to the list above, e.g. `mic_f32_gain: 2.5` (linear; ~2.0 ≈ +6 dB).
#
# Better accuracy (slower / more RAM): `whisper_hf_repo: "openai/whisper-base"`
# Faster screen updates but messier merges: lower `whisper_chunk_seconds` (default 6).
